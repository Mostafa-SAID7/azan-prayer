# ============================================
# Payer - Prayer Times PWA Environment Config
# ============================================

# Prayer Times API Configuration
VITE_ALADHAN_API_URL=https://api.aladhan.com/v1

# Default Location (used on first load)
VITE_DEFAULT_CITY=Cairo
VITE_DEFAULT_COUNTRY=Egypt
VITE_DEFAULT_METHOD=5

# App Configuration
VITE_APP_NAME=Payer
VITE_APP_TITLE=Islamic Prayer Times
VITE_APP_VERSION=0.1.0

# Debug Mode (development only)
VITE_DEBUG=false

# Feature Flags
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_PWA=true
VITE_ENABLE_QURAN=true

# Analytics (if implemented)
# VITE_ANALYTICS_ID=your_analytics_id

# API Rate Limiting
VITE_API_CACHE_TIME=3600

# Deployment Configuration
NODE_ENV=production
VITE_MODE=production

# PWA Configuration
VITE_ENABLE_SERVICE_WORKER=true
VITE_PWA_CACHE_STRATEGY=network-first

# Security
VITE_API_TIMEOUT=8000
VITE_MAX_RETRIES=3
